# =============================================================================
# DocuMind AI — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# ── General ──────────────────────────────────────────────────────────────────
# Application environment: development | production | testing
ENVIRONMENT=development

# Secret key for JWT signing and Fernet encryption (min 32 chars, keep secret!)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-very-long-secret-key-min-32-chars

# ── Backend (FastAPI) ─────────────────────────────────────────────────────────
# Host and port the FastAPI server binds to
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Frontend (Next.js) ───────────────────────────────────────────────────────
# Public API URL — must be reachable from the browser
NEXT_PUBLIC_API_URL=http://localhost:8000

# Internal backend URL — used by Next.js server-side rewrites (Docker: use service name)
# Docker Compose: http://backend:8000 | Local dev: http://localhost:8000
BACKEND_URL=http://backend:8000

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite connection string (aiosqlite async driver)
# Data is persisted via a Docker volume mounted at ./data/
DATABASE_URL=sqlite+aiosqlite:///./data/documind.db

# ChromaDB persistent directory (embedded, no server required)
CHROMA_PERSIST_DIR=./data/chroma

# ── File Storage ─────────────────────────────────────────────────────────────
# Storage backend: local | s3
STORAGE_BACKEND=local

# Path for local file storage (relative to backend workdir)
STORAGE_LOCAL_PATH=./data/uploads

# S3-compatible storage (only if STORAGE_BACKEND=s3)
# S3_BUCKET=your-bucket-name
# S3_REGION=ap-southeast-1
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_ENDPOINT_URL=                  # Optional: custom endpoint (e.g. MinIO)

# ── RAG Settings ─────────────────────────────────────────────────────────────
# Document chunk size in tokens
CHUNK_SIZE=1024

# Token overlap between consecutive chunks
CHUNK_OVERLAP=128

# Number of top chunks to retrieve per query
RAG_TOP_K=8

# Minimum similarity threshold to include a chunk (0.0–1.0)
RAG_SIMILARITY_THRESHOLD=0.3

# ── LLM Providers (user-managed BYOK) ────────────────────────────────────────
# These are not required — users configure their own keys via the UI.
# They can be pre-seeded here for automated / CI environments.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIza...
# OPENROUTER_API_KEY=sk-or-v1-...
# MISTRAL_API_KEY=...
# GROQ_API_KEY=gsk_...

# Ollama base URL (for local LLM inference, no API key required)
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Use * for development; set explicit origins in production.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Requests per minute per IP (0 = disabled)
RATE_LIMIT_PER_MINUTE=60

# ── Logging ──────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
